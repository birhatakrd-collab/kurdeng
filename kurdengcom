        <div class="settings-group">
            <select id="themeSelect" onchange="changeTheme()">
                <option value="dark" data-i18n="theme_dark">تاریک (Dark)</option>
                <option value="black" data-i18n="theme_black">ڕەش (Pitch Black)</option>
                <option value="light" data-i18n="theme_light">ڕووناهی (Light)</option>
