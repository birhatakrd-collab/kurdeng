<!DOCTYPE html>
<html lang="ku" dir="rtl" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kurdeng - کوردینگ</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @font-face {
            font-family: 'Rabar_041';
            src: local('Rabar_041');
        }

        :root {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --card-border: #333333;
            --text-main: #f0f0f0;
            --text-muted: #aaaaaa;
            --gold: #d4af37;
            --gold-light: #fbe69b;
            --accent-purple: #9d88ff;
        }
        [data-theme="black"] {
            --bg-color: #000000;
            --card-bg: #0a0a0a;
            --card-border: #1f1f1f;
            --text-main: #e0e0e0;
            --text-muted: #777777;
            --gold: #c5a028;
            --gold-light: #ffd700;
            --accent-purple: #b3a3ff;
        }
        [data-theme="light"] {
            --bg-color: #f4f7f6;
            --card-bg: #ffffff;
            --card-border: #dddddd;
            --text-main: #111111;
            --text-muted: #555555;
            --gold: #b8860b;
            --gold-light: #d4af37;
            --accent-purple: #6a4cff;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Rabar_041', Tahoma, Arial, sans-serif;
            -webkit-tap-highlight-color: transparent;
            transition: background-color 0.3s, color 0.3s;
        }

        body { background-color: var(--bg-color); color: var(--text-main); overflow-x: hidden; line-height: 1.6; }

        /* Header */
        header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 15px 20px; background-color: var(--card-bg);
            border-bottom: 1px solid var(--card-border); position: sticky; top: 0; z-index: 100; direction: ltr; 
        }
        .header-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .logo-icon { font-size: 28px; color: var(--gold); }
        .logo-text { font-size: 24px; font-weight: bold; background: linear-gradient(45deg, var(--gold), var(--gold-light)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .menu-btn { background: none; border: none; color: var(--text-main); font-size: 24px; cursor: pointer; }

        /* Drawer Menu */
        .drawer-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 999; display: none; opacity: 0; transition: opacity 0.3s; }
        [dir="rtl"] .drawer-menu { right: -300px; border-left: 2px solid var(--gold); }
        [dir="ltr"] .drawer-menu { left: -300px; border-right: 2px solid var(--gold); }
        .drawer-menu { position: fixed; top: 0; width: 280px; height: 100%; background-color: var(--card-bg); z-index: 1000; transition: 0.4s ease; display: flex; flex-direction: column; padding: 30px 20px; }
        [dir="rtl"] .drawer-menu.open { right: 0; }
        [dir="ltr"] .drawer-menu.open { left: 0; }
        .drawer-overlay.open { display: block; opacity: 1; }
        .drawer-logo { text-align: center; margin-bottom: 30px; font-size: 28px; font-weight: bold; color: var(--gold); }
        .drawer-links { list-style: none; flex-grow: 1; }
        .drawer-links li { margin-bottom: 15px; }
        .drawer-links a { color: var(--text-main); text-decoration: none; font-size: 18px; display: flex; align-items: center; gap: 15px; padding: 10px; border-radius: 8px; }
        .drawer-links a:hover { background: rgba(212,175,55,0.1); color: var(--gold); }
        .settings-group { margin-top: auto; border-top: 1px solid var(--card-border); padding-top: 20px; }
        .settings-group select { width: 100%; padding: 10px; margin-bottom: 10px; background: var(--bg-color); color: var(--text-main); border: 1px solid var(--card-border); border-radius: 8px; font-family: 'Rabar_041', sans-serif; font-size: 16px; outline: none; }

        .page { display: none; padding: 20px; max-width: 800px; margin: auto; animation: fadeIn 0.4s; }
        .page.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Ad Banner */
        .ad-banner { background: linear-gradient(135deg, var(--card-bg) 0%, rgba(212, 175, 55, 0.1) 100%); border: 1px solid var(--gold); border-radius: 16px; padding: 20px; text-align: center; margin-bottom: 25px; box-shadow: 0 4px 15px rgba(212, 175, 55, 0.1); }
        .ad-banner h3 { color: var(--gold); font-size: 22px; margin-bottom: 5px; }
        .ad-banner p { font-size: 15px; color: var(--text-muted); margin-bottom: 15px; }
        .ad-contact { display: inline-block; padding: 10px 20px; border-radius: 25px; background: var(--gold); color: #000; font-weight: bold; font-size: 16px; text-decoration: none; direction: ltr; box-shadow: 0 4px 10px rgba(212,175,55,0.3); }

        /* Search */
        .search-box { display: flex; align-items: center; background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 12px; padding: 5px 15px; margin-bottom: 20px; }
        .search-box:focus-within { border-color: var(--gold); }
        .search-box input { background: transparent; border: none; color: var(--text-main); padding: 12px; width: 100%; font-size: 16px; outline: none; }
        .search-box i { color: var(--text-muted); }

        /* Levels */
        .level-card { background: var(--card-bg); border-radius: 12px; padding: 20px; margin-bottom: 15px; border: 1px solid var(--card-border); cursor: pointer; display: flex; flex-direction: column; transition: 0.2s; }
        .level-card:hover { border-color: var(--gold); }
        .level-title { font-size: 20px; font-weight: bold; color: var(--text-main); margin-bottom: 10px; direction: ltr; text-align: left; }
        .level-info { display: flex; justify-content: space-between; color: var(--text-muted); font-size: 14px; direction: ltr; }

        /* Word List */
        .word-item { background: var(--card-bg); border-radius: 10px; padding: 15px; margin-bottom: 10px; border: 1px solid var(--card-border); cursor: pointer; display: flex; justify-content: space-between; align-items: center; transition: 0.2s; }
        .word-item:hover { border-color: var(--gold); }
        .word-en-title { font-size: 18px; font-weight: bold; color: var(--text-main); direction: ltr; }
        .word-ku-preview { color: var(--text-muted); font-size: 14px; }

        /* Word Detail */
        .nav-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
        .back-btn { background: none; border: none; color: var(--text-muted); font-size: 20px; cursor: pointer; }
        .word-number { color: var(--text-muted); font-size: 16px; }

        .image-placeholder { background: var(--card-bg); border-radius: 12px; border: 1px solid var(--card-border); height: 200px; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--card-border); margin-bottom: 20px; font-size: 20px; font-weight: bold; letter-spacing: 2px; }
        .image-placeholder i { font-size: 60px; margin-bottom: 10px; }

        .meaning-card { background: var(--card-bg); border-radius: 12px; padding: 20px; margin-bottom: 20px; border: 1px solid var(--card-border); }
        .mc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px; }
        .mc-word-en { font-size: 28px; font-weight: bold; color: var(--accent-purple); display: flex; align-items: center; gap: 10px; direction: ltr; }
        .mc-word-ku { font-size: 24px; font-weight: bold; color: var(--accent-purple); }
        .mc-pos { display: flex; justify-content: space-between; font-size: 14px; color: var(--text-muted); margin-bottom: 15px; }
        .pos-en { direction: ltr; }
        
        .mc-divider { height: 1px; background: var(--card-border); margin: 15px 0; }
        
        .mc-def-en { font-size: 16px; color: var(--text-main); margin-bottom: 10px; direction: ltr; text-align: left; }
        .mc-def-ku { font-size: 16px; color: var(--text-main); text-align: right; }
        
        .mc-ex-label { font-size: 14px; color: var(--text-main); font-weight: bold; margin-bottom: 10px; direction: ltr; text-align: left;}
        .mc-ex-en { font-size: 16px; color: var(--text-main); margin-bottom: 10px; direction: ltr; text-align: left; }
        .mc-ex-ku { font-size: 16px; color: var(--text-muted); text-align: right; }

        /* Highlight Word in Example */
        .hl-word { color: var(--gold-light); font-weight: bold; text-decoration: underline; text-decoration-color: var(--gold-light); }

        .play-icon { cursor: pointer; transition: 0.2s; }
        .play-icon:hover { color: var(--gold); }

        /* About */
        .profile-img { width: 100px; height: 100px; background: var(--card-bg); border: 2px solid var(--gold); border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; font-size: 40px; color: var(--gold); }
        .about-text { font-size: 16px; color: var(--text-muted); margin-bottom: 30px; text-align: justify; line-height: 1.8; }
        .social-btn { background: var(--card-bg); color: var(--text-main); padding: 15px; border-radius: 10px; text-decoration: none; border: 1px solid var(--card-border); font-size: 16px; display: flex; justify-content: space-between; margin-bottom: 15px; transition: 0.3s; }
        .social-btn:hover { border-color: var(--gold); }
        .social-handle { color: var(--text-muted); direction: ltr;}

    </style>
</head>
<body>

    <header>
        <a href="#" class="header-logo" onclick="showPage('home')">
            <i class="fas fa-book-reader logo-icon"></i>
            <span class="logo-text">Kurdeng</span>
        </a>
        <button class="menu-btn" onclick="toggleMenu()"><i class="fas fa-bars"></i></button>
    </header>

    <div class="drawer-overlay" id="drawerOverlay" onclick="toggleMenu()"></div>
    <nav class="drawer-menu" id="drawerMenu">
        <div class="drawer-logo">Kurdeng</div>
        <ul class="drawer-links">
