        let currentLang = 'ku';

        function toggleMenu() { document.getElementById('drawerMenu').classList.toggle('open'); document.getElementById('drawerOverlay').classList.toggle('open'); }
        function showPage(pageId) { document.querySelectorAll('.page').forEach(page => page.classList.remove('active')); document.getElementById(pageId).classList.add('active'); window.scrollTo({ top: 0, behavior: 'smooth' }); }
        function changeTheme() { document.documentElement.setAttribute('data-theme', document.getElementById('themeSelect').value); }

        function changeLanguage() {
            currentLang = document.getElementById('langSelect').value;
            const isRtl = (currentLang === 'ku' || currentLang === 'ar');
            document.documentElement.setAttribute('dir', isRtl ? 'rtl' : 'ltr');
            document.documentElement.setAttribute('lang', currentLang);

            const arrowClass = isRtl ? 'fa-arrow-right' : 'fa-arrow-left';
            document.getElementById('backIconLevel').className = `fas ${arrowClass}`;
            document.getElementById('backIconWord').className = `fas ${arrowClass}`;
            document.getElementById('backIconAbout').className = `fas ${arrowClass}`;

            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (uiTranslations[currentLang][key]) el.innerText = uiTranslations[currentLang][key];
            });
            document.querySelectorAll('[data-i18n-ph]').forEach(el => {
                const key = el.getAttribute('data-i18n-ph');
                if (uiTranslations[currentLang][key]) el.placeholder = uiTranslations[currentLang][key];
            });
        }

        function openLevel(levelCode, levelName, startNum, endNum) {
            document.getElementById('current-level-title').innerText = levelName;
            const wordsListDiv = document.getElementById('words-list');
            wordsListDiv.innerHTML = '';

            const levelWords = dictionary.filter(w => w.lvl === levelCode);
            if(levelWords.length === 0) {
                wordsListDiv.innerHTML = `<p style="text-align:center; color:var(--text-muted);">بۆ ڤی ئاستی هێشتا پەیڤ نەهاتینە زێدەکرن.</p>`;
            } else {
                levelWords.forEach(obj => {
                    const div = document.createElement('div');
                    div.className = 'word-item';
                    div.onclick = () => openWordDetail(obj);
                    const previewKu = obj.meanings.map(m => m.ku).join('، ');
                    div.innerHTML = `
                        <span class="word-en-title">${obj.id}. ${obj.word}</span>
                        <span class="word-ku-preview">${previewKu}</span>
                    `;
                    wordsListDiv.appendChild(div);
                });
            }
            showPage('level-view');
        }

        function openWordDetail(wordObj) {
            document.getElementById('detail-word-num').innerText = `# ${wordObj.id}`;
            const container = document.getElementById('meanings-container');
            container.innerHTML = '';

            wordObj.meanings.forEach(m => {
                // Remove HTML tags for Speech Synthesis so it doesn't read "span class hl word"
                const plainExEn = m.exEn.replace(/<[^>]*>?/gm, ''); 

                const card = document.createElement('div');
                card.className = 'meaning-card';
                card.innerHTML = `
                    <div class="mc-header">
                        <div class="mc-word-en">
                            <i class="fas fa-volume-up play-icon" onclick="playSound('${wordObj.word}', '${plainExEn}')"></i>
                            ${wordObj.word}
                        </div>
                        <div class="mc-word-ku">${m.ku}</div>
                    </div>
                    <div class="mc-pos">
                        <span class="pos-en">${m.posEn}</span>
                        <span>${m.posKu}</span>
                    </div>
                    <div class="mc-def-en">${m.defEn}</div>
                    <div class="mc-def-ku">${m.defKu}</div>
                    <div class="mc-divider"></div>
                    <div class="mc-ex-label">Example</div>
                    <div class="mc-ex-en">${m.exEn}</div>
                    <div class="mc-ex-ku">${m.exKu}</div>
                `;
                container.appendChild(card);
            });

            showPage('word-detail');
        }

        function searchWords() {
            const val = document.getElementById('searchInput').value.trim().toLowerCase();
            const levelsContainer = document.getElementById('levels-container');
            const searchResults = document.getElementById('search-results');
            
            if(val === "") {
                levelsContainer.style.display = 'block'; searchResults.style.display = 'none'; return;
            }

            levelsContainer.style.display = 'none'; searchResults.style.display = 'block'; searchResults.innerHTML = '';

            const filtered = dictionary.filter(obj => obj.word.toLowerCase().includes(val) || obj.meanings.some(m => m.ku.includes(val)));

            if(filtered.length === 0) {
                searchResults.innerHTML = '<p style="text-align:center; color:var(--text-muted);">چ ئەنجام نەهاتنە دیتن.</p>';
            } else {
                filtered.forEach(obj => {
                    const div = document.createElement('div');
                    div.className = 'word-item';
                    div.onclick = () => openWordDetail(obj);
                    const previewKu = obj.meanings.map(m => m.ku).join('، ');
                    div.innerHTML = `
                        <span class="word-en-title">${obj.word} <span style="font-size:12px; font-weight:normal;">(${obj.lvl})</span></span>
                        <span class="word-ku-preview">${previewKu}</span>
                    `;
                    searchResults.appendChild(div);
                });
            }
        }

        function playSound(word, example) {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel(); 
                let wordMsg = new SpeechSynthesisUtterance(word);
                wordMsg.lang = 'en-US';
                window.speechSynthesis.speak(wordMsg);
                
                let exMsg = new SpeechSynthesisUtterance(example);
                exMsg.lang = 'en-US';
                wordMsg.onend = () => { setTimeout(() => { window.speechSynthesis.speak(exMsg); }, 400); };
            }
        }

        changeLanguage();
    </script>
